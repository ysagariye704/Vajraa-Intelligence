# Environment Variables for Vajraa Intelligence

# API Configuration
# For development (default): uses Vite proxy
# For production: set to your Render backend URL
VITE_API_URL=https://your-backend-name.onrender.com/api

# Example production URLs:
# VITE_API_URL=https://varaa-backend.onrender.com/api
# VITE_API_URL=https://varaa-intelligence-backend.onrender.com/api