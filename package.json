{
  "name": "varaa-intelligence",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "cd backend && python manage.py runserver 8000",
    "build": "vite build",
    "start": "vite preview --host 0.0.0.0 --port $PORT",
    "serve": "npm run build && cd backend && python manage.py runserver 8000",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.14.2",
    "recharts": "^2.9.0",
    "serve": "^14.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.4",
    "vite": "^5.4.1"
  }
}
